generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  DOCTOR
  PATIENT
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum BloodType {
  A_POSITIVE
  A_NEGATIVE
  B_POSITIVE
  B_NEGATIVE
  AB_POSITIVE
  AB_NEGATIVE
  O_POSITIVE
  O_NEGATIVE
  UNKNOWN
}

// ─── Auth ────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(PATIENT)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  patient  Patient?
  doctor   Doctor?

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Specialty & Office ──────────────────────────────────────────────────────

model Specialty {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  icon        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  doctors Doctor[]

  @@map("specialties")
}

model Office {
  id          String   @id @default(cuid())
  number      String   @unique
  floor       Int
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  doctors      Doctor[]
  appointments Appointment[]

  @@map("offices")
}

// ─── Doctor ──────────────────────────────────────────────────────────────────

model Doctor {
  id              String    @id @default(cuid())
  userId          String    @unique
  specialtyId     String
  officeId        String?
  licenseNumber   String    @unique
  phone           String?
  bio             String?   @db.Text
  yearsExperience Int       @default(0)
  gender          Gender?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialty    Specialty     @relation(fields: [specialtyId], references: [id])
  office       Office?       @relation(fields: [officeId], references: [id])
  schedules    Schedule[]
  appointments Appointment[]
  consultations Consultation[]

  @@map("doctors")
}

model Schedule {
  id        String   @id @default(cuid())
  doctorId  String
  dayOfWeek Int      // 0 = Sunday … 6 = Saturday
  startTime String   // "08:00"
  endTime   String   // "17:00"
  slotMinutes Int    @default(30)
  isActive  Boolean  @default(true)

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@map("schedules")
}

// ─── Patient ─────────────────────────────────────────────────────────────────

model Patient {
  id            String     @id @default(cuid())
  userId        String     @unique
  dateOfBirth   DateTime?
  gender        Gender?
  bloodType     BloodType  @default(UNKNOWN)
  phone         String?
  address       String?
  emergencyName String?
  emergencyPhone String?
  allergies     String[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments      Appointment[]
  clinicalHistories ClinicalHistory[]

  @@map("patients")
}

// ─── Appointments ─────────────────────────────────────────────────────────────

model Appointment {
  id          String            @id @default(cuid())
  patientId   String
  doctorId    String
  officeId    String?
  date        DateTime
  startTime   String
  endTime     String
  status      AppointmentStatus @default(PENDING)
  reason      String?           @db.Text
  notes       String?           @db.Text
  isVirtual   Boolean           @default(false)
  meetingUrl  String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  patient      Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor       Doctor        @relation(fields: [doctorId], references: [id])
  office       Office?       @relation(fields: [officeId], references: [id])
  consultation Consultation?

  @@map("appointments")
}

// ─── Clinical History ─────────────────────────────────────────────────────────

model ClinicalHistory {
  id        String   @id @default(cuid())
  patientId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient       Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  consultations Consultation[]

  @@map("clinical_histories")
}

model Consultation {
  id                String   @id @default(cuid())
  clinicalHistoryId String
  appointmentId     String   @unique
  doctorId          String
  chiefComplaint    String   @db.Text
  diagnosis         String   @db.Text
  treatment         String?  @db.Text
  notes             String?  @db.Text
  aiSummary         String?  @db.Text
  aiPatientExplain  String?  @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  clinicalHistory ClinicalHistory @relation(fields: [clinicalHistoryId], references: [id])
  appointment     Appointment     @relation(fields: [appointmentId], references: [id])
  doctor          Doctor          @relation(fields: [doctorId], references: [id])
  prescriptions   Prescription[]
  exams           Exam[]

  @@map("consultations")
}

model Prescription {
  id             String   @id @default(cuid())
  consultationId String
  medication     String
  dosage         String
  frequency      String
  duration       String
  instructions   String?  @db.Text
  createdAt      DateTime @default(now())

  consultation Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)

  @@map("prescriptions")
}

model Exam {
  id             String    @id @default(cuid())
  consultationId String
  name           String
  description    String?
  fileUrl        String?
  resultNotes    String?   @db.Text
  completedAt    DateTime?
  createdAt      DateTime  @default(now())

  consultation Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)

  @@map("exams")
}

// ─── Audit ───────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entity     String
  entityId   String?
  oldValues  Json?
  newValues  Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@map("audit_logs")
}
